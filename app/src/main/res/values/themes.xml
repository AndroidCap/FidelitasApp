<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema principal do app -->
    <style name="Theme.FidelitasApp" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Tema da Splash Screen (API 31+) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FidelitasApp</item>
    </style>
</resources>